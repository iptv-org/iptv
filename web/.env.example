# Porta e host (a plataforma normalmente define PORT automaticamente).
PORT=3000
HOST=0.0.0.0

# Origem dos dados (padrão: API pública do iptv-org).
IPTV_API_BASE=https://iptv-org.github.io/api

# Atualização automática do dataset, em minutos (0 desabilita). Padrão: 360 (6h).
REFRESH_INTERVAL_MIN=360

# Confiar no X-Forwarded-* (IP/protocolo reais). Defina 1 apenas quando atrás de
# um proxy reverso confiável (Render/Fly/Railway/etc.). Em execução direta,
# deixe 0/vazio para o rate-limit por IP não ser burlável. Padrão: desligado.
TRUST_PROXY=0

# Limite de requisições por minuto por IP no proxy /stream. Padrão: 600.
STREAM_RATE_MAX=600

# Token para proteger POST /api/reload (envie no header x-reload-token).
# Se vazio, o endpoint /api/reload fica desabilitado (responde 403).
RELOAD_TOKEN=
